# ========== 必填 ==========
# JWT 签名密钥（请使用随机字符串，至少 32 字符）
JWT_SECRET=your-random-secret-at-least-32-chars

# ========== 数据库（可选，Railway 部署时无需设置，默认使用 /data/data.db） ==========
# 本地开发时如需自定义路径，取消注释并修改：
# DATABASE_PATH=./data.db

# ========== Railway 卷持久化说明 ==========
# railway.toml 已配置 [volumes] data = "/data"
# db.ts 默认使用 /data/data.db，容器重启后数据不丢失
# 如果 Railway 上未配置卷，请到 Railway Dashboard → 项目 → Settings → Volumes 添加挂载路径 /data

# ========== 可选 ==========
# Cron 任务密钥（Railway 定时任务使用）
# CRON_SECRET=your-cron-secret

# 运行环境
# NODE_ENV=production
